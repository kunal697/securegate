{
  "name": "securegate-desktop",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "cp -r ../dashboard ./backend/ && cp ../securegate.env ./securegate.env || true",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.securegate.desktop",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "loading.html",
      "src/**/*",
      "backend/**/*"
    ],
    "asarUnpack": [
      "backend/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.2",
    "sudo-prompt": "^9.2.1"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  }
}
# =============================================================================
# SecureGate – Configuration & credentials
# =============================================================================
# 1. Copy this file to securegate.env (or .env):
#      cp securegate.env.example securegate.env
# 2. Edit securegate.env: set the options you need and add your API keys.
# 3. Start the app: ./start_securegate.sh
#    (Or: source securegate.env && ./start_securegate.sh)
#
# Do NOT commit securegate.env or .env – they are gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# How to run: detectors and mode
# -----------------------------------------------------------------------------
# Lite mode = only pattern + prompt_injection (no NER, semantic, LLM classifier).
# Set to false to enable all detectors (or the ones you list in SECUREGATE_DETECTORS).
# SECUREGATE_LITE_MODE=true
SECUREGATE_LITE_MODE=false

# Comma-separated list of detectors to run. Omit any to disable it.
# Options: pattern, prompt_injection, gliner, ner, semantic, llm_classifier
#   gliner = zero-shot NER (pip install -r requirements-gliner.txt)
# Example: all six (with GLiNER):
#   SECUREGATE_DETECTORS=pattern,prompt_injection,gliner,ner,semantic,llm_classifier
SECUREGATE_DETECTORS=pattern,prompt_injection,ner,semantic,llm_classifier

# GLiNER model (when gliner detector enabled).
#   urchade/gliner_medium-v2.1 = zero-shot (default)
#   nvidia/gliner-pii = PII/PHI (55+ types, NVIDIA Open Model License)
# SECUREGATE_GLINER_MODEL=urchade/gliner_medium-v2.1
# SECUREGATE_GLINER_MODEL=nvidia/gliner-pii

# GLiNER confidence threshold (default 0.5). nvidia/gliner-pii eval used 0.3.
# SECUREGATE_GLINER_THRESHOLD=0.5

# NER spaCy model: en_core_web_sm (less RAM) or en_core_web_lg (better accuracy).
# SECUREGATE_SPACY_MODEL=en_core_web_lg
SECUREGATE_SPACY_MODEL=en_core_web_sm

# -----------------------------------------------------------------------------
# LLM backend: which LLM to use for classifier + /chat
# -----------------------------------------------------------------------------
# Options: local | gemini | self_hosted
#
#   local        – Classifier uses local BART (needs transformers/torch).
#                  Chat uses OpenAI (needs OPENAI_API_KEY below).
#   gemini       – Classifier + chat use Google Gemini. Set GEMINI_API_KEY below.
#   self_hosted  – Classifier + chat use your own LLM. Set SECUREGATE_LLM_BASE_URL
#                  and SECUREGATE_LLM_API_KEY below.
#
SECUREGATE_LLM_BACKEND=gemini

# Model name for Gemini (see https://ai.google.dev/gemini-api/docs/models/gemini).
# Examples: gemini-2.0-flash, gemini-3-flash-preview. Older names like gemini-1.5-flash may 404.
# SECUREGATE_LLM_MODEL=gemini-2.0-flash
SECUREGATE_LLM_MODEL=gemini-2.0-flash

# Min seconds between Gemini API calls (classifier + chat). Default 1.0 = at most 1 request/sec.
# SECUREGATE_GEMINI_MIN_INTERVAL=1.0

# -----------------------------------------------------------------------------
# Credentials – fill in the ones you use (leave empty or commented if not used)
# -----------------------------------------------------------------------------

# Required when SECUREGATE_LLM_BACKEND=gemini
# Get a key at: https://aistudio.google.com/app/apikey
# Get a key from Google AI Studio: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=

# Required for /chat when SECUREGATE_LLM_BACKEND=local (OpenAI).
# OPENAI_API_KEY=

# Required when SECUREGATE_LLM_BACKEND=self_hosted
# SECUREGATE_LLM_BASE_URL=https://your-llm-server.com/v1
# SECUREGATE_LLM_API_KEY=your_self_hosted_api_key

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
# Host and port for the SecureGate API.
# SECUREGATE_HOST=0.0.0.0
# SECUREGATE_PORT=8000
SECUREGATE_HOST=0.0.0.0
SECUREGATE_PORT=8000

# Used by the MITM proxy addon to call SecureGate (if you run the proxy).
# SECUREGATE_URL=http://127.0.0.1:8000
SECUREGATE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Optional: MITM proxy (for intercepting AI traffic system-wide)
# -----------------------------------------------------------------------------
# Proxy port when you run with --with-proxy.
# SECUREGATE_PROXY_PORT=8080
SECUREGATE_PROXY_PORT=8080
